{
  "name": "@perryts/threads",
  "version": "0.1.1",
  "description": "Parallel array processing via Web Workers — parallelMap, parallelFilter, spawn. Works in browsers and Node.js.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "threads",
    "parallel",
    "web-workers",
    "worker-pool",
    "parallelMap",
    "parallelFilter",
    "spawn",
    "concurrency",
    "perry"
  ],
  "author": "Perry Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PerryTS/perry.git",
    "directory": "packages/perry-threads"
  },
  "homepage": "https://github.com/PerryTS/perry/tree/main/packages/perry-threads#readme",
  "bugs": {
    "url": "https://github.com/PerryTS/perry/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
