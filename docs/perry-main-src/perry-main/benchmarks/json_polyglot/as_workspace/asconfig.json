{
  "extends": "./node_modules/@assemblyscript/wasi-shim/asconfig.json",
  "options": {
    "transform": ["json-as/transform"],
    "exportRuntime": true,
    "bindings": "esm"
  },
  "targets": {
    "release": {
      "outFile": "build/release.wasm",
      "textFile": "build/release.wat",
      "optimizeLevel": 3,
      "shrinkLevel": 0,
      "converge": false,
      "noAssert": true
    }
  }
}
