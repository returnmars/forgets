"\n"
"while (!windowShouldClose()) {\n"
"  beginDrawing();\n"
"  clearBackground(Colors.BLACK);\n"
"\n"
"  if (isGamepadButtonDown(0)) {\n"
"    // A button (Siri Remote select) pressed\n"
"  }\n"
"\n"
"  endDrawing();\n"
"}\n"
