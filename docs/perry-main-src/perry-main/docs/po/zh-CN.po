"const analyzeButton = Button(\"Analyze\", async () => {\n"
"    status.set(\"Processing...\")\n"
"\n"
"    // Background thread — UI stays responsive\n"
"    const data = await spawn(() => {\n"
"        let count = 0\n"
"        for (let i = 0; i < 1_000_000; i++) {\n"
"            if ((i & 0xff) === 0) count++\n"
