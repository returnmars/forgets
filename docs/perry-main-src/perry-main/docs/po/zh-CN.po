"format = \"appimage\"\n"
"category = \"Development\"\n"
"description = \"A cross-platform Perry application\"\n"
"\n"
"[i18n]\n"
"locales = [\"en\", \"de\", \"fr\"]\n"
"default_locale = \"en\"\n"
"\n"
