"```typescript\n"
"const searchInput = TextField(\"Search...\", (v: string) => search.set(v))\n"
"widgetMatchParentWidth(searchInput)\n"
"const results = VStack(8, [])\n"
"const searchPage = VStack(12, [searchInput, results])\n"
"```"
