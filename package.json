{
  "name": "forgets-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "npm run typecheck && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "perry:doctor": "perry doctor",
    "m0": "powershell -ExecutionPolicy Bypass -File scripts/forgets-m0.ps1",
    "m1:http": "powershell -ExecutionPolicy Bypass -File scripts/forgets-m1-http.ps1",
    "m1:http:start": "powershell -ExecutionPolicy Bypass -File scripts/forgets-m1-http-start.ps1"
  },
  "devDependencies": {
    "@perryts/perry": "^0.5.511",
    "@types/node": "^20.12.12",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "fastify": "^5.8.5"
  }
}
